  # Lambda function to create domain credentials secret with actual password
  DomainCredentialsFunction:
    Metadata:
      cfn_nag:
        rules_to_suppress:
          - id: W89
            reason: The lambda does not need to be deployed in a VPC.
          - id: W92
            reason: This is for demo only. ReservedConcurrentExecutions can be ignored.
    Type: AWS::Lambda::Function
    DependsOn: HybridAssessmentLambdaRole
    Properties:
      FunctionName: !Sub "${AWS::StackName}-domain-credentials"
      Runtime: python3.11
      Handler: index.lambda_handler
      Role: !GetAtt HybridAssessmentLambdaRole.Arn
      Timeout: 300
      Code:
        ZipFile: |
          import json
          import boto3
          import cfnresponse
          import logging
          
          logger = logging.getLogger()
          logger.setLevel(logging.INFO)
          
          def lambda_handler(event, context):
              try:
                  if event['RequestType'] == 'Create':
                      secrets_client = boto3.client('secretsmanager')
                      
                      # Get the actual password from the admin password secret
                      admin_secret_arn = event['ResourceProperties']['AdminPasswordArn']
                      admin_response = secrets_client.get_secret_value(SecretId=admin_secret_arn)
                      admin_secret = json.loads(admin_response['SecretString'])
                      actual_password = admin_secret['password']
                      
                      # Create the domain credentials secret with the actual password
                      secret_name = event['ResourceProperties']['SecretName']
                      domain_credentials = {
                          "customerAdAdminDomainUsername": "Administrator",
                          "customerAdAdminDomainPassword": actual_password
                      }
                      
                      response = secrets_client.create_secret(
                          Name=secret_name,
                          Description="Domain administrator credentials for hybrid AD assessment",
                          SecretString=json.dumps(domain_credentials)
                      )
                      
                      logger.info(f"Created domain credentials secret: {response['ARN']}")
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {'SecretArn': response['ARN']})
                      
                  elif event['RequestType'] == 'Delete':
                      secrets_client = boto3.client('secretsmanager')
                      secret_name = event['ResourceProperties']['SecretName']
                      try:
                          secrets_client.delete_secret(SecretId=secret_name, ForceDeleteWithoutRecovery=True)
                      except:
                          pass  # Secret might not exist
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {})
                      
                  else:
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {})
                      
              except Exception as e:
                  logger.error(f"Error: {str(e)}")
                  cfnresponse.send(event, context, cfnresponse.FAILED, {'Error': str(e)})

