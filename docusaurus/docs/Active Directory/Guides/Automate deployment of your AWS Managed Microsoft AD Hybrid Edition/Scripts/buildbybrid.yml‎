      Handler: index.lambda_handler
      Role: !GetAtt LayerDownloadRole.Arn
      Timeout: 600
      Code:
        ZipFile: |
          import json
          import boto3
          import cfnresponse
          import logging
          import subprocess
          import os
          import shutil
          
          logger = logging.getLogger()
          logger.setLevel(logging.INFO)
          
          def lambda_handler(event, context):
              try:
                  if event['RequestType'] == 'Create':
                      bucket_name = event['ResourceProperties']['BucketName']
                      
                      logger.info("Creating boto3 layer with pip install")
                      
                      # Create layer directory
                      layer_dir = '/tmp/python'
                      os.makedirs(layer_dir, exist_ok=True)
                      
                      # Install boto3 and dependencies to layer directory
                      subprocess.run([
                          'pip', 'install', 'boto3==1.40.14', 
                          '--target', layer_dir, 
                          '--no-cache-dir'
                      ], check=True)
                      
                      logger.info("Boto3 installation completed")
                      
                      # Create zip file
                      zip_path = '/tmp/boto3-layer.zip'
                      shutil.make_archive('/tmp/boto3-layer', 'zip', '/tmp', 'python')
                      
                      logger.info(f"Created layer zip: {os.path.getsize(zip_path)} bytes")
                      
                      # Upload to S3 bucket
                      s3_client = boto3.client('s3')
                      s3_client.upload_file(zip_path, bucket_name, 'boto3-layer.zip')
                      
                      logger.info("Layer uploaded to S3 successfully")
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {'S3Key': 'boto3-layer.zip'})
                  else:
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {})
                      
              except Exception as e:
                  logger.error(f"Error: {str(e)}")
                  import traceback
                  logger.error(f"Traceback: {traceback.format_exc()}")
                  cfnresponse.send(event, context, cfnresponse.FAILED, {'Error': str(e)})

