  # Lambda function for hybrid assessment
  HybridAssessmentFunction:
    Metadata:
      cfn_nag:
        rules_to_suppress:
          - id: W89
            reason: The lambda does not need to be deployed in a VPC
          - id: W92
            reason: This is for demo only. ReservedConcurrentExecutions can be ignored.
    Type: AWS::Lambda::Function
    DependsOn: DomainController2
    Properties:
      FunctionName: !Sub "${AWS::StackName}-hybrid-assessment"
      Runtime: python3.11
      Handler: index.lambda_handler
      Role: !GetAtt HybridAssessmentLambdaRole.Arn
      Timeout: 900
      Layers:
        - !Ref Boto3Layer
      Code:
        ZipFile: |
          import json
          import boto3
          import cfnresponse
          import logging
          import time
          
          logger = logging.getLogger()
          logger.setLevel(logging.INFO)
          
          def lambda_handler(event, context):
              logger.info(f"Event: {json.dumps(event)}")
              
              try:
                  ds_client = boto3.client('ds')
                  
                  if event['RequestType'] == 'Create':
                      response = start_assessment(ds_client, event['ResourceProperties'])
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, response, response['AssessmentId'])
                  
                  elif event['RequestType'] in ['Update', 'Delete']:
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {})
                      
              except Exception as e:
                  logger.error(f"Lambda handler error: {str(e)}")
                  import traceback
                  logger.error(f"Traceback: {traceback.format_exc()}")
                  cfnresponse.send(event, context, cfnresponse.FAILED, {})
          
          def start_assessment(ds_client, properties):
              logger.info("Starting AD Assessment with correct API structure")
              
              secret_arn = properties['SecretArn']
              credentials = get_credentials_from_secret(secret_arn)
              
              # Build assessment configuration with correct structure
              assessment_config = {
                  'CustomerDnsIps': [
                      properties['DomainController1IP'],
                      properties['DomainController2IP']
                  ],
                  'DnsName': properties['DomainName'],
                  'VpcSettings': {
                      'VpcId': properties['VpcId'],
                      'SubnetIds': [
                          properties['SubnetId1'],
                          properties['SubnetId2']
                      ]
                  },
                  'InstanceIds': [
                      properties['DomainController1InstanceId'],
                      properties['DomainController2InstanceId']
                  ]
              }
              
              logger.info(f"Assessment config: {json.dumps(assessment_config)}")
              
              try:
                  response = ds_client.start_ad_assessment(
                      AssessmentConfiguration=assessment_config
                  )
                  
                  assessment_id = response['AssessmentId']
                  logger.info(f"Assessment started with ID: {assessment_id}")
                  
                  return {
                      'AssessmentId': assessment_id,
                      'Status': 'Started',
                      'DomainName': properties['DomainName'],
                      'DomainControllerIPs': [properties['DomainController1IP'], properties['DomainController2IP']],
                      'InstanceIds': [properties['DomainController1InstanceId'], properties['DomainController2InstanceId']]
                  }
                  
              except Exception as e:
                  logger.error(f"Failed to start assessment: {str(e)}")
                  return {
                      'AssessmentId': 'failed',
                      'Status': 'FAILED',
                      'Error': str(e),
                      'Message': 'Assessment failed to start'
                  }
          
          def get_credentials_from_secret(secret_arn):
              secrets_client = boto3.client('secretsmanager')
              response = secrets_client.get_secret_value(SecretId=secret_arn)
              return json.loads(response['SecretString'])

