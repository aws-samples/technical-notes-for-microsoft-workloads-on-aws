      DomainController2InstanceId: !Ref DomainController2
      VpcId: !Ref VPC
      SubnetId1: !Ref PublicSubnet1
      SubnetId2: !Ref PublicSubnet2

  # Lambda function to monitor assessment and create hybrid directory
  HybridDirectoryFunction:
    Metadata:
      cfn_nag:
        rules_to_suppress:
          - id: W89
            reason: The lambda does not need to be deployed in a VPC
          - id: W92
            reason: This is for demo only. ReservedConcurrentExecutions can be ignored.
    Type: AWS::Lambda::Function
    Properties:
      FunctionName: !Sub "${AWS::StackName}-hybrid-directory"
      Runtime: python3.11
      Handler: index.lambda_handler
      Role: !GetAtt HybridAssessmentLambdaRole.Arn
      Timeout: 900
      Layers:
        - !Ref Boto3Layer
      Code:
        ZipFile: |
          import json
          import boto3
          import cfnresponse
          import logging
          import time
          
          logger = logging.getLogger()
          logger.setLevel(logging.INFO)
          
          def lambda_handler(event, context):
              try:
                  if event['RequestType'] == 'Create':
                      ds_client = boto3.client('ds')
                      assessment_id = event['ResourceProperties']['AssessmentId']
                      secret_arn = event['ResourceProperties']['SecretArn']
                      
                      logger.info(f"Monitoring assessment: {assessment_id}")
                      
                      # Monitor for up to 30 minutes
                      for i in range(60):
                          response = ds_client.describe_ad_assessment(AssessmentId=assessment_id)
                          status = response['Assessment']['Status']
                          
                          logger.info(f"Check {i+1}: Status = {status}")
                          
                          if status == 'SUCCESS':
                              # Create hybrid directory
                              hybrid_response = ds_client.create_hybrid_ad(
                                  AssessmentId=assessment_id,
                                  SecretArn=secret_arn
                              )
                              
                              directory_id = hybrid_response['DirectoryId']
                              logger.info(f"Hybrid directory created: {directory_id}")
                              
                              cfnresponse.send(event, context, cfnresponse.SUCCESS, 
                                             {'DirectoryId': directory_id})
                              return
                              
                          elif status == 'FAILURE':
                              logger.error("Assessment failed")
                              cfnresponse.send(event, context, cfnresponse.FAILED, 
                                             {'Error': 'Assessment failed'})
                              return
                          
                          time.sleep(30)
                      
                      # Timeout
                      logger.error("Assessment timeout")
                      cfnresponse.send(event, context, cfnresponse.FAILED, 
                                     {'Error': 'Assessment timeout'})
                  else:
                      cfnresponse.send(event, context, cfnresponse.SUCCESS, {})
                      
              except Exception as e:
                  logger.error(f"Error: {str(e)}")
                  cfnresponse.send(event, context, cfnresponse.FAILED, {'Error': str(e)})

  # Custom Resource for Hybrid Directory Creation
  HybridDirectoryResource:
    Type: AWS::CloudFormation::CustomResource
    DependsOn: HybridAssessmentResource
    Properties:
      ServiceToken: !GetAtt HybridDirectoryFunction.Arn
      AssessmentId: !GetAtt HybridAssessmentResource.AssessmentId
      SecretArn: !GetAtt DomainCredentialsSecret.SecretArn

Outputs:
  VPCId:
    Description: VPC ID
    Value: !Ref VPC
    Export:
      Name: !Sub "${AWS::StackName}-VPC-ID"

  DomainName:
    Description: Active Directory Domain Name
    Value: onprem.com

  AdminPasswordSecret:
    Description: Secrets Manager ARN for Administrator password
    Value: !Ref AdminPassword

  DomainController1IP:
    Description: Primary Domain Controller IP
    Value: !GetAtt DomainController1.PrivateIp

  DomainController2IP:
    Description: Secondary Domain Controller IP
    Value: !GetAtt DomainController2.PrivateIp

  AssessmentId:
    Description: "ID of the AD assessment"
    Value: !GetAtt HybridAssessmentResource.AssessmentId
  
  AssessmentStatus:
    Description: "Status of the AD assessment"
    Value: !GetAtt HybridAssessmentResource.Status
  
  DirectoryId:
    Description: "ID of the created Hybrid Directory"
    Value: !GetAtt HybridDirectoryResource.DirectoryId
  
  DomainCredentialsSecret:
    Description: "ARN of the domain credentials secret"
    Value: !GetAtt DomainCredentialsSecret.SecretArn
